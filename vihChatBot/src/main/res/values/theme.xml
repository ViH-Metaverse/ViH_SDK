<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <string name="font_family_light">sans-serif-light</string>
    <string name="font_family_medium">sans-serif-medium</string>
    <string name="font_family_regular">sans-serif</string>
    <string name="font_family_condensed">sans-serif-condensed</string>
    <string name="font_family_black">sans-serif-black</string>
    <string name="font_family_thin">sans-serif-thin</string>

    <style name="BottomNavTextFont">

    </style>


    <style name="OrderStatusStyleSelected">
        <item name="android:paddingTop">@dimen/_7sdp</item>
        <item name="android:paddingBottom">@dimen/_7sdp</item>
        <item name="android:paddingStart">@dimen/_5sdp</item>
        <item name="android:paddingEnd">@dimen/_5sdp</item>
        <item name="android:textSize">@dimen/_8ssp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/rubik_bold</item>
    </style>

    <style name="OrderStatusStyleUnSelected">
        <item name="android:paddingTop">@dimen/_7sdp</item>
        <item name="android:paddingBottom">@dimen/_7sdp</item>
        <item name="android:paddingStart">@dimen/_5sdp</item>
        <item name="android:paddingEnd">@dimen/_5sdp</item>
        <item name="android:textSize">@dimen/_8ssp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/rubik_regular</item>
    </style>

    <style name="Theme.VihChatbot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primarycolor</item>
        <item name="colorPrimaryVariant">@color/primarycolor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondarycolor</item>
        <item name="colorSecondaryVariant">@color/secondarycolor</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- System-theme-aware defaults: window background + text flip in dark mode.
             Tenant colors applied to specific views at runtime still win over these. -->
        <item name="android:windowBackground">@color/vih_screen_bg</item>
        <item name="android:textColorPrimary">@color/vih_text_primary</item>
        <item name="android:textColorSecondary">@color/vih_text_secondary</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Dark status-bar icons in light mode, light icons in dark mode. -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">@bool/vih_light_status_bar</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="myIconGradientStart">@color/primarycolor</item>
        <item name="myIconGradientMid">@color/primarycolor</item>
        <item name="myIconGradientEnd">@color/primarycolor</item>
    </style>

    <style name="Theme.VihChatbot.DashBoardActivity" parent="Theme.VihChatbot"></style>
</resources>