<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:clickable="true"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

    <!-- Profile Header -->
    <LinearLayout
        android:id="@+id/linearMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivback"
                android:padding="@dimen/_5sdp"
                android:layout_margin="@dimen/_5sdp"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:src="@drawable/ic_arrow_back"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_5sdp"
                android:fontFamily="@font/rubik_regular"
                android:padding="@dimen/_10sdp"
                android:text="Edit"
                android:textColor="@color/primarycolor"
                android:textSize="@dimen/_12ssp" />

            <FrameLayout
                android:id="@+id/imageContainer"
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_80sdp"
                android:layout_centerHorizontal="true"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_20sdp">

                <com.vihmessenger.vihchatbot.utils.CircleImageView
                    android:id="@+id/ivProfileImage"
                    android:layout_width="match_parent"
                    app:civ_border_width="0.5dp"
                    app:civ_circle_background_color="@color/status_bar_grey"
                    android:layout_height="match_parent"
                    android:src="@drawable/edit_profile_placeholder"
                    tools:src="@tools:sample/avatars" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>


            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/imageContainer"
                android:layout_centerHorizontal="true"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_10sdp"
                android:fontFamily="@font/rubik_medium"
                android:text="Name"
                android:textColor="@color/white"
                android:textSize="@dimen/_16ssp" />

            <TextView
                android:id="@+id/tvProfilePhoneNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tvProfileName"
                android:layout_centerHorizontal="true"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:fontFamily="@font/rubik_regular"
                android:text="Number"
                android:textColor="#B9B9B9" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_30sdp"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:padding="@dimen/_10sdp">

        <!-- Notifications & Alerts Section -->
        <TextView
            android:id="@+id/notificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:fontFamily="@font/rubik_medium"
            android:text="Notifications &amp; Alerts"
            android:textColor="@color/vih_text_primary"
            android:textSize="@dimen/_14ssp" />

        <RelativeLayout
            android:id="@+id/rlNotiifcationLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/notification_icon"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_notifications_settings" />

            <TextView
                android:id="@+id/tv_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/swtNotificationStatus"
                android:layout_toEndOf="@id/notification_icon"
                android:fontFamily="@font/rubik_regular"
                android:text="Notifications"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <Switch
                android:id="@+id/swtNotificationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:enabled="false"
                android:textOff="Off"
                android:textOn="On"
                />
        </RelativeLayout>

        <!-- Privacy & Security Settings Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:fontFamily="@font/rubik_medium"
            android:text="Privacy &amp; Security Settings"
            android:textColor="@color/vih_text_primary"
            android:textSize="@dimen/_14ssp" />

        <RelativeLayout
            android:id="@+id/rvBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/block_icon"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_block" />

            <TextView
                android:id="@+id/tv_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow"
                android:layout_toEndOf="@id/block_icon"
                android:fontFamily="@font/rubik_regular"
                android:text="Blocked Senders"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <!-- Help & Support Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:fontFamily="@font/rubik_medium"
            android:text="Help &amp; Support"
            android:textColor="@color/vih_text_primary"
            android:textSize="@dimen/_14ssp" />

        <!-- Terms of Use -->
        <RelativeLayout
            android:id="@+id/rvTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/ic_terms"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_terms" />

            <TextView
                android:id="@+id/tv_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow_terms"
                android:layout_toEndOf="@id/ic_terms"
                android:fontFamily="@font/rubik_regular"
                android:text="Terms of Use"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <!-- Privacy Policy -->
        <RelativeLayout
            android:id="@+id/rvPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/ic_policy"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_privacy" />

            <TextView
                android:id="@+id/tv_policy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow_policy"
                android:layout_toEndOf="@id/ic_policy"
                android:fontFamily="@font/rubik_regular"
                android:text="Privacy Policy"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow_policy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <!-- Account Settings Section -->
        <TextView
            android:id="@+id/tvAccountSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:fontFamily="@font/rubik_medium"
            android:text="Account Settings"
            android:textColor="@color/vih_text_primary"
            android:textSize="@dimen/_14ssp" />

        <!-- Change Channel Hashkey (app only) -->
        <RelativeLayout
            android:id="@+id/rvChangeHashkey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/hashkey_icon"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_terms" />

            <TextView
                android:id="@+id/tv_hashkey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow_hashkey"
                android:layout_toEndOf="@id/hashkey_icon"
                android:fontFamily="@font/rubik_regular"
                android:text="Change Channel Hashkey"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow_hashkey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <!-- Delete Account Request -->
        <RelativeLayout
            android:id="@+id/rvDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/delete_icon"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_delete" />

            <TextView
                android:id="@+id/tv_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow_delete"
                android:layout_toEndOf="@id/delete_icon"
                android:fontFamily="@font/rubik_regular"
                android:text="Delete Account Request"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>

        <!-- Logout -->
        <RelativeLayout
            android:id="@+id/rvLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp">

            <ImageView
                android:id="@+id/logout_icon"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Item icon"
                android:src="@drawable/ic_logout" />

            <TextView
                android:id="@+id/tv_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@id/ic_arrow_logout"
                android:layout_toEndOf="@id/logout_icon"
                android:fontFamily="@font/rubik_regular"
                android:text="Logout"
                android:textColor="@color/vih_text_primary"
                android:textSize="@dimen/_12ssp" />

            <ImageView
                android:id="@+id/ic_arrow_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_right" />
        </RelativeLayout>
    </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>