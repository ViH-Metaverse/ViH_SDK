<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_2sdp"
    android:background="@drawable/custom_notification_bg_rounded"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_6sdp">

        <TextView
            android:id="@+id/notification_title_expanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Notification Title"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/notification_message_expanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_toStartOf="@+id/notification_icon_expanded"
                android:text="This is a detailed notification message that can span multiple lines and provides more context to the user."
                android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/notification_icon_expanded"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Notification Icon"
                android:src="@drawable/ic_notification" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/notification_image_container_expanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/notification_image_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:background="#E0E0E0"
                android:contentDescription="Notification Content Image"
                android:maxHeight="200dp"
                android:minHeight="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder" />

            <ImageView
                android:id="@+id/notification_center_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerInParent="true"
                android:alpha="0.7"
                android:contentDescription="Center Icon"
                android:src="@drawable/ic_play"
                android:visibility="gone" />
        </RelativeLayout>

    </LinearLayout>
</LinearLayout>