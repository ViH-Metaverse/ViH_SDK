<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/voicebotRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_24sdp"
        android:alpha="0.7"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Calling ViH Shruti…" />

    <TextView
        android:id="@+id/tvAgentName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_6sdp"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        tools:text="ViH Shruti" />

    <com.vihmessenger.vihchatbot.ui.widget.VoicebotOrbView
        android:id="@+id/orbView"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="@dimen/_260sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/llControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_48sdp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMute"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/bg_voicebot_mute"
            android:contentDescription="Mute microphone"
            android:src="@drawable/ic_mic_on"
            android:scaleType="centerInside"
            android:padding="@dimen/_14sdp" />

        <View
            android:layout_width="@dimen/_36sdp"
            android:layout_height="1dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHangUp"
            android:layout_width="@dimen/_72sdp"
            android:layout_height="@dimen/_72sdp"
            android:background="@drawable/bg_voicebot_hangup"
            android:contentDescription="End call"
            android:src="@drawable/ic_call_end"
            android:scaleType="centerInside"
            android:padding="@dimen/_18sdp" />

        <View
            android:layout_width="@dimen/_36sdp"
            android:layout_height="1dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:background="@drawable/bg_voicebot_mute"
            android:contentDescription="Toggle speaker"
            android:src="@drawable/ic_speaker_on"
            android:scaleType="centerInside"
            android:padding="@dimen/_14sdp" />
    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.constraintlayout.widget.ConstraintLayout>
